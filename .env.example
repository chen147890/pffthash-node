# PFFT / pffthash.com Ethereum PoW mint.
ETH_RPC_URL=https://ethereum-rpc.publicnode.com

# Use a dedicated EVM mint wallet. Do not use your main wallet.
EVM_PRIVATE_KEY=

# auto = use all logical CPU cores.
PFFT_THREADS=auto
PFFT_BATCH_SIZE=4096
PFFT_NONCE_MODE=sequential
PFFT_REPORT_INTERVAL_MS=5000

# auto = use CUDA when runtime/bin/pfft-cuda-miner exists, plus CPU workers.
# cpu = CPU only, cuda = CUDA only, hybrid = CUDA + CPU.
PFFT_MINER_MODE=auto
PFFT_CUDA_DEVICES=auto
PFFT_CUDA_BLOCKS=4096
PFFT_CUDA_THREADS=256
PFFT_CUDA_ITERATIONS=64

# 1 = submit freeMint(powNonce) after finding a valid nonce.
# 0 = only print solved nonce, do not send transaction.
PFFT_AUTO_SUBMIT=1
PFFT_CONTINUE_ON_TX_ERROR=1
PFFT_ERROR_BACKOFF_MS=5000

# Dynamic EIP-1559 gas settings. Defaults aim for low cost.
PFFT_GAS_STRATEGY=cheap
PFFT_GAS_LIMIT_MULTIPLIER_PERMILLE=1100
PFFT_BASE_FEE_MULTIPLIER_PERMILLE=1050
PFFT_FEE_HISTORY_BLOCKS=5
PFFT_FEE_HISTORY_PERCENTILE=10
PFFT_MIN_PRIORITY_FEE_GWEI=0.05

# 1 = mint once and exit.
# 0 = keep mining forever.
PFFT_MINT_COUNT=1

# Minimum ETH balance required before mining starts.
PFFT_MIN_ETH_BALANCE=0.003
